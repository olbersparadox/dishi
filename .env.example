NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Vision + voice extraction. If absent, the app falls back to a mock classifier so the loop still demos.
ANTHROPIC_API_KEY=
# Google Places API key (Nearby Search). Optional — without it, the restaurant
# quick-pick uses only Dishi's own restaurant list, no error, just fewer suggestions.
# IMPORTANT once you add a real key: in Google Cloud Console, set a daily request cap
# on this API (APIs & Services -> Quotas) as a hard safety net against runaway billing —
# the app-level cache in src/lib/placesCache.ts helps but a project-level cap is the
# real backstop.
GOOGLE_PLACES_API_KEY=
# Protects /api/mf/train (the matrix-factorization retraining job). Set to any random
# string; Vercel's cron will send it automatically once set as an env var there too.
CRON_SECRET=
